{
  "name": "inscada-chat",
  "version": "1.0.0",
  "description": "inSCADA AI Chat - Claude API + MCP Tools",
  "main": "electron-main.js",
  "scripts": {
    "start": "electron .",
    "start:server": "node server.js",
    "dev": "node --watch server.js",
    "mcp": "node mcp-server.mjs",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.inscada.chat",
    "productName": "inSCADA Chat",
    "files": [
      "electron-main.js",
      "preload.js",
      "server.js",
      "tools.js",
      "tool-handlers.js",
      "mcp-server.mjs",
      "settings.html",
      "public/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "pg": "^8.13.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  }
}
